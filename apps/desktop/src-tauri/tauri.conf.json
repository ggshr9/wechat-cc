{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wechat-cc",
  "version": "0.2.2",
  "identifier": "dev.wechat-cc.installer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "wechat-cc",
        "width": 1100,
        "height": 860,
        "minWidth": 760,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "rpm", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/wechat-cc-cli"
    ]
  }
}
