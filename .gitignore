node_modules/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Runtime state — all channel data lives under ~/.claude/channels/wechat/,
# not in the repo. These patterns defend against accidental local copies
# landing inside the source tree.
accounts/
*.log
*.pid
.env
.env.*
access.json
context_tokens.json
user_names.json
inbox/
*@im.wechat/

# Build artifacts
dist/
build/
*.tsbuildinfo

# Tauri / Rust desktop installer build output (gigabytes; never commit)
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/gen/schemas/
apps/desktop/src-tauri/WixTools/
# Sidecar binaries are produced per-platform during CI (`bun build --compile`)
# and bundled into the Tauri output. Never commit — they're 60+ MB and machine-
# specific; CI rebuilds them before each desktop release.
apps/desktop/src-tauri/binaries/

# Playwright MCP snapshots — local debugging artifacts
.playwright-mcp/

# Claude Code local state
.claude/
*.bun-build
