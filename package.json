{
  "name": "claude-channel-wechat",
  "version": "0.4.5",
  "description": "WeChat channel plugin for Claude Code \u2014 bridge WeChat messages in and out of your Claude Code session via the ilink bot API.",
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "wechat",
    "ilink",
    "channel"
  ],
  "homepage": "https://github.com/ggshr9/wechat-cc#readme",
  "bugs": {
    "url": "https://github.com/ggshr9/wechat-cc/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ggshr9/wechat-cc.git"
  },
  "author": "ggshr9",
  "license": "MIT",
  "type": "module",
  "bin": {
    "wechat-cc": "./cli.ts"
  },
  "scripts": {
    "start": "bun install --no-summary && bun src/daemon/main.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.116",
    "@openai/codex": "0.128.0",
